# Backend Environment Variables
# Copy this to .env and fill in values

PORT=3000
NODE_ENV=production

# Authentication
API_TOKEN=your-secure-api-token-here

# Gmail API
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://your-app.onrender.com/api/v1/gmail/auth/oauth2callback

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI Summarization (optional cloud model)
# Leave empty to use local/custom summarizer
OPENAI_API_KEY=
AI_MODEL=

# Database
DATABASE_PATH=./data/agent.db