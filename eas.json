{
  "eas": {
    "build": {
      "development": {
        "developmentClient": true,
        "distribution": "internal",
        "android": {
          "buildType": "apk",
          "gradleCommand": ":app:assembleDebug"
        },
        "ios": {
          "buildType": "simulator"
        }
      },
      "preview": {
        "distribution": "internal",
        "android": {
          "buildType": "apk"
        },
        "ios": {
          "buildType": "simulator"
        }
      },
      "production": {
        "android": {
          "buildType": "app-bundle"
        },
        "ios": {
          "buildType": "app-store"
        },
        "autoIncrement": true
      }
    },
    "submit": {
      "production": {
        "android": {
          "track": "internal"
        }
      }
    }
  }
}