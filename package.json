    "expo": "~54.0.33",
    "expo-background-fetch": "~14.0.9",
    "expo-calendar": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
